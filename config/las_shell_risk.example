# ─────────────────────────────────────────────────────────────
# ~/.las_shell_risk  —  Las_shell Risk Limit Configuration (Phase 4.3)
#
# Loaded once at shell startup via load_risk_config().
# Reload at runtime with:  riskconfig reload
# View active limits with:  riskconfig show
#
# Format:   KEY = VALUE        (whitespace around = is ignored)
#           # lines are comments, blank lines are ignored
#           Unknown keys are silently ignored (forward-compatible)
# ─────────────────────────────────────────────────────────────

# ── Position / order sizing ──────────────────────────────────

# Maximum shares / contracts per single order
MAX_POSITION_SIZE = 1000

# Minimum shares / contracts per single order
MIN_POSITION_SIZE = 1

# Maximum dollar notional value per single order (size * price)
# Orders with no price supplied skip this check
MAX_ORDER_NOTIONAL = 500000

# Maximum number of orders that may be submitted in one trading day
MAX_ORDERS_PER_DAY = 50

# ── P&L / risk limits ────────────────────────────────────────

# Maximum portfolio drawdown (%) before assert / ?> gate fires
# Checked when running:  assert    (zero-arg form)
# against $DRAWDOWN environment variable
MAX_DRAWDOWN_PCT = 5.0

# Maximum daily loss ($) before assert / ?> gate fires
# Checked against $DAILY_LOSS environment variable
MAX_DAILY_LOSS = 2000

# ── Symbol universe ──────────────────────────────────────────

# Comma-separated list of permitted symbols.
# If this list is present, ONLY these symbols will be allowed
# through the ?> risk gate.  Remove or comment out to allow all.
ALLOWED_SYMBOLS = SPY,QQQ,IWM,AAPL,MSFT

# Comma-separated list of always-blocked symbols.
# Checked before the allowed list — blocked takes priority.
BLOCKED_SYMBOLS = GME,AMC,BBBY
